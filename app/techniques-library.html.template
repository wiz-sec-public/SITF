<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SITF Technique Library - Visual Explorer</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="sitf-icon-round.png">

    <!-- Fonts: Poppins (Wiz Style) + JetBrains Mono for IDs -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --wiz-dark-bg: #0f0f0f;
            --wiz-dark-surface: #1a1a1a;
            --wiz-dark-border: #333333;
            --wiz-dark-hover: #252525;
            --wiz-text-primary: #e5e5e5;
            --wiz-text-secondary: #a0a0a0;
            --wiz-accent-purple: #FC80FF;
            --wiz-success: #10B981;
            --wiz-danger: #EF4444;
            --wiz-warning: #F59E0B;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: var(--wiz-dark-bg);
            min-height: 100vh;
            padding: 0;
            color: var(--wiz-text-primary);
        }

        /* Header */
        .header {
            background: var(--wiz-dark-surface);
            border-bottom: 1px solid var(--wiz-dark-border);
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 16px;
            margin-bottom: 15px;
            position: relative;
        }

        .header::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg,
                transparent,
                rgba(252, 128, 255, 0.3) 20%,
                rgba(252, 128, 255, 0.3) 80%,
                transparent
            );
        }

        .header-logo {
            height: 36px;
            filter: drop-shadow(0 2px 8px rgba(252, 128, 255, 0.2));
        }

        .header-title h1 {
            font-family: 'JetBrains Mono', monospace;
            font-size: 18px;
            font-weight: 600;
            color: var(--wiz-accent-purple);
            letter-spacing: -0.02em;
        }

        .header-title p {
            font-size: 12px;
            color: var(--wiz-text-secondary);
            margin-top: 2px;
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 0 15px 15px 15px;
        }

        .filters {
            background: var(--wiz-dark-surface);
            border-radius: 10px;
            padding: 14px;
            margin-bottom: 15px;
            border: 1px solid var(--wiz-dark-border);
            display: flex;
            gap: 15px;
            align-items: center;
            flex-wrap: wrap;
        }

        .filter-group {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .filter-group label {
            font-weight: 600;
            color: var(--wiz-text-secondary);
            font-size: 0.85rem;
            white-space: nowrap;
        }

        .filter-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .filter-btn {
            padding: 8px 14px;
            border: 1px solid var(--wiz-dark-border);
            background: var(--wiz-dark-bg);
            border-radius: 6px;
            cursor: pointer;
            font-size: 0.8rem;
            transition: all 0.2s ease;
            color: var(--wiz-text-secondary);
        }

        .filter-btn:hover {
            border-color: var(--wiz-accent-purple);
            background: var(--wiz-dark-hover);
            color: var(--wiz-text-primary);
        }

        .filter-btn.active {
            background: var(--wiz-accent-purple);
            color: var(--wiz-dark-bg);
            border-color: var(--wiz-accent-purple);
            font-weight: 500;
        }

        .search-box {
            flex: 1;
            min-width: 200px;
            padding: 10px 14px;
            border: 1px solid var(--wiz-dark-border);
            background: var(--wiz-dark-bg);
            border-radius: 8px;
            font-size: 0.85rem;
            transition: all 0.2s ease;
            color: var(--wiz-text-primary);
        }

        .search-box::placeholder {
            color: var(--wiz-text-secondary);
        }

        .search-box:focus {
            outline: none;
            border-color: var(--wiz-accent-purple);
            background: var(--wiz-dark-hover);
            box-shadow: 0 0 0 3px rgba(252, 128, 255, 0.1);
        }

        .stats {
            background: var(--wiz-dark-surface);
            border-radius: 10px;
            padding: 12px 20px;
            margin-bottom: 15px;
            border: 1px solid var(--wiz-dark-border);
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 15px;
        }

        .stat-item {
            text-align: center;
        }

        .stat-number {
            font-family: 'JetBrains Mono', monospace;
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--wiz-accent-purple);
        }

        .stat-label {
            color: var(--wiz-text-secondary);
            font-size: 0.75rem;
            margin-top: 2px;
        }

        .component-section {
            background: var(--wiz-dark-surface);
            border-radius: 12px;
            padding: 18px;
            margin-bottom: 15px;
            border: 1px solid var(--wiz-dark-border);
        }

        .component-header {
            display: flex;
            align-items: center;
            margin-bottom: 14px;
            padding-bottom: 10px;
            border-bottom: 2px solid;
        }

        .component-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            margin-right: 12px;
            color: white;
        }

        .component-info h2 {
            font-size: 1.3rem;
            margin-bottom: 2px;
            color: var(--wiz-text-primary);
        }

        .component-info p {
            color: var(--wiz-text-secondary);
            font-size: 0.8rem;
        }

        .stage-group {
            margin-bottom: 15px;
        }

        .stage-group:last-child {
            margin-bottom: 0;
        }

        .stage-header {
            background: var(--wiz-dark-bg);
            padding: 10px 14px;
            border-radius: 8px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border: 1px solid var(--wiz-dark-border);
        }

        .stage-title {
            font-size: 1rem;
            font-weight: 600;
            color: var(--wiz-text-primary);
        }

        .stage-count {
            font-family: 'JetBrains Mono', monospace;
            background: var(--wiz-accent-purple);
            color: var(--wiz-dark-bg);
            padding: 4px 12px;
            border-radius: 12px;
            font-size: 0.75rem;
            font-weight: 600;
        }

        .techniques-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 12px;
        }

        .technique-card {
            border: 1px solid var(--wiz-dark-border);
            border-radius: 10px;
            padding: 14px;
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--wiz-dark-bg);
        }

        .technique-card:hover {
            border-color: var(--wiz-accent-purple);
            box-shadow: 0 4px 16px rgba(252, 128, 255, 0.15);
            transform: translateY(-2px);
        }

        .technique-card:target,
        .technique-card.highlighted {
            border-color: var(--wiz-accent-purple);
            box-shadow: 0 0 0 2px rgba(252, 128, 255, 0.3);
            animation: highlight-pulse 2s ease-out;
        }

        @keyframes highlight-pulse {
            0% { box-shadow: 0 0 0 4px rgba(252, 128, 255, 0.5); }
            100% { box-shadow: 0 0 0 2px rgba(252, 128, 255, 0.3); }
        }

        .technique-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 6px;
        }

        .copy-link-btn {
            background: transparent;
            border: none;
            color: var(--wiz-text-secondary);
            cursor: pointer;
            padding: 4px 8px;
            font-size: 0.75rem;
            border-radius: 4px;
            transition: all 0.2s;
            opacity: 0;
        }

        .technique-card:hover .copy-link-btn {
            opacity: 1;
        }

        .copy-link-btn:hover {
            background: var(--wiz-dark-hover);
            color: var(--wiz-text-primary);
        }

        .copy-link-btn.copied {
            color: var(--wiz-success);
        }

        .technique-id {
            font-family: 'JetBrains Mono', monospace;
            display: inline-block;
            background: var(--wiz-dark-hover);
            color: var(--wiz-accent-purple);
            padding: 4px 10px;
            border-radius: 5px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-bottom: 8px;
            letter-spacing: -0.02em;
        }

        .technique-name {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--wiz-text-primary);
            margin-bottom: 6px;
            line-height: 1.3;
        }

        .technique-description {
            color: var(--wiz-text-secondary);
            font-size: 0.8rem;
            line-height: 1.5;
            margin-bottom: 10px;
        }

        .technique-details {
            border-top: 1px solid var(--wiz-dark-border);
            padding-top: 10px;
        }

        .detail-section {
            margin-bottom: 10px;
        }

        .detail-section:last-child {
            margin-bottom: 0;
        }

        .detail-title {
            font-weight: 600;
            color: var(--wiz-text-primary);
            font-size: 0.75rem;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .detail-list {
            list-style: none;
        }

        .detail-list li {
            color: var(--wiz-text-secondary);
            font-size: 0.75rem;
            line-height: 1.5;
            padding-left: 14px;
            position: relative;
            margin-bottom: 4px;
        }

        .detail-list li::before {
            content: "•";
            position: absolute;
            left: 4px;
            color: var(--wiz-dark-border);
        }

        .risks-list li::before {
            color: var(--wiz-danger);
        }

        .controls-list li::before {
            color: var(--wiz-success);
        }

        .framework-tags {
            margin-left: 6px;
        }

        .framework-tag {
            font-family: 'JetBrains Mono', monospace;
            display: inline-block;
            background: rgba(252, 128, 255, 0.1);
            color: var(--wiz-accent-purple);
            font-size: 0.6em;
            padding: 2px 6px;
            border-radius: 4px;
            margin-left: 4px;
            font-weight: 600;
            border: 1px solid rgba(252, 128, 255, 0.2);
            vertical-align: middle;
            white-space: pre-line;
        }

        .framework-tag:hover {
            background: rgba(252, 128, 255, 0.2);
            border-color: var(--wiz-accent-purple);
            cursor: help;
        }

        .no-results {
            background: var(--wiz-dark-surface);
            border-radius: 12px;
            padding: 50px 20px;
            text-align: center;
            border: 1px solid var(--wiz-dark-border);
        }

        .no-results-icon {
            font-size: 3rem;
            margin-bottom: 15px;
            opacity: 0.3;
        }

        .no-results h3 {
            color: var(--wiz-text-primary);
            font-size: 1.2rem;
            margin-bottom: 8px;
        }

        .no-results p {
            color: var(--wiz-text-secondary);
        }

        .hidden {
            display: none !important;
        }

        @media (max-width: 768px) {
            .header {
                padding: 12px 16px;
            }

            .header-title h1 {
                font-size: 16px;
            }

            .techniques-grid {
                grid-template-columns: 1fr;
            }

            .stats {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <div class="header">
        <img src="sitf-icon-round.png" alt="SITF" class="header-logo">
        <div class="header-title">
            <h1>SITF Technique Library</h1>
            <p>Browse and search all SDLC supply chain attack techniques</p>
        </div>
    </div>

    <div class="container">
        <div class="filters">
            <div class="filter-group">
                <label>Component:</label>
                <div class="filter-buttons" id="componentFilters"></div>
            </div>

            <div class="filter-group">
                <label>Stage:</label>
                <div class="filter-buttons" id="stageFilters"></div>
            </div>

            <div class="filter-group" style="flex: 1;">
                <input type="text" class="search-box" id="searchBox" placeholder="Search techniques...">
            </div>
        </div>

        <div class="stats" id="stats"></div>

        <div id="techniquesContainer"></div>

        <div class="no-results hidden" id="noResults">
            <div class="no-results-icon">🔍</div>
            <h3>No techniques found</h3>
            <p>Try adjusting your filters or search terms</p>
        </div>
    </div>

    <script>
        {{EMBEDDED_DATA}}

        // Component colors
        const componentColors = {
            'endpoint': '#3B82F6',
            'vcs': '#10B981',
            'cicd': '#F59E0B',
            'registry': '#8B5CF6',
            'production': '#EF4444'
        };

        // Component icons
        const componentIcons = {
            'endpoint': '💻',
            'vcs': '📦',
            'cicd': '⚙️',
            'registry': '📚',
            'production': '☁️'
        };

        // Helper function to format framework tags - one tag per framework with tooltip showing all mappings
        function formatFrameworkTags(control) {
            if (!control.frameworks) return '';
            
            const frameworkDefs = techniquesData.frameworkDefinitions || {};
            const tags = [];
            
            Object.entries(control.frameworks).forEach(([frameworkId, values]) => {
                const frameworkDef = frameworkDefs[frameworkId];
                if (!frameworkDef || !Array.isArray(values) || values.length === 0) return;
                
                // Group by stage for organized tooltip
                const stageGroups = {};
                values.forEach(v => {
                    const catMeta = frameworkDef.categories?.[v];
                    if (catMeta) {
                        if (!stageGroups[catMeta.stage]) {
                            stageGroups[catMeta.stage] = [];
                        }
                        stageGroups[catMeta.stage].push({ id: v, name: catMeta.name });
                    }
                });
                
                // Build tooltip with all stages and categories
                const tooltipLines = [`${frameworkDef.name} v${frameworkDef.version}`];
                Object.entries(stageGroups).forEach(([stage, cats]) => {
                    tooltipLines.push(`\n${stage}:`);
                    cats.forEach(c => tooltipLines.push(`  ${c.id}: ${c.name}`));
                });
                
                // Create single tag for this framework
                const displayName = frameworkId.toUpperCase();
                tags.push(`<span class="framework-tag" title="${tooltipLines.join('\n')}">${displayName}</span>`);
            });
            
            return tags.length > 0 ? ` <span class="framework-tags">${tags.join('')}</span>` : '';
        }

        // State
        let filters = {
            component: 'all',
            stage: 'all',
            search: ''
        };

        // Initialize
        function init() {
            renderFilters();
            renderTechniques();
            setupEventListeners();
        }

        // Render filter buttons
        function renderFilters() {
            const componentFilters = document.getElementById('componentFilters');
            const stageFilters = document.getElementById('stageFilters');

            // Component filters
            let componentHTML = '<button class="filter-btn active" data-filter="all">All Components</button>';
            techniquesData.components.forEach(comp => {
                componentHTML += `<button class="filter-btn" data-filter="${comp.id}">${comp.name}</button>`;
            });
            componentFilters.innerHTML = componentHTML;

            // Stage filters
            const stages = ['Initial Access', 'Discovery and Lateral Movement', 'Post-Compromise'];
            let stageHTML = '<button class="filter-btn active" data-filter="all">All Stages</button>';
            stages.forEach(stage => {
                stageHTML += `<button class="filter-btn" data-filter="${stage}">${stage}</button>`;
            });
            stageFilters.innerHTML = stageHTML;
        }

        // Setup event listeners
        function setupEventListeners() {
            // Component filters
            document.getElementById('componentFilters').addEventListener('click', (e) => {
                if (e.target.classList.contains('filter-btn')) {
                    document.querySelectorAll('#componentFilters .filter-btn').forEach(btn => {
                        btn.classList.remove('active');
                    });
                    e.target.classList.add('active');
                    filters.component = e.target.dataset.filter;
                    renderTechniques();
                }
            });

            // Stage filters
            document.getElementById('stageFilters').addEventListener('click', (e) => {
                if (e.target.classList.contains('filter-btn')) {
                    document.querySelectorAll('#stageFilters .filter-btn').forEach(btn => {
                        btn.classList.remove('active');
                    });
                    e.target.classList.add('active');
                    filters.stage = e.target.dataset.filter;
                    renderTechniques();
                }
            });

            // Search
            document.getElementById('searchBox').addEventListener('input', (e) => {
                filters.search = e.target.value.toLowerCase();
                renderTechniques();
            });
        }

        // Filter techniques
        function filterTechniques() {
            return techniquesData.techniques.filter(tech => {
                // Component filter
                if (filters.component !== 'all' && tech.component !== filters.component) {
                    return false;
                }

                // Stage filter
                if (filters.stage !== 'all' && tech.stage !== filters.stage) {
                    return false;
                }

                // Search filter
                if (filters.search) {
                    const searchText = filters.search;
                    // Extract control names from new schema
                    const protectiveControls = (tech.controls?.protective || []).map(c => c.name || c);
                    const detectiveControls = (tech.controls?.detective || []).map(c => c.name || c);
                    const allControls = [...protectiveControls, ...detectiveControls];
                    
                    const searchableText = [
                        tech.id,
                        tech.name,
                        tech.description,
                        ...tech.risks,
                        ...allControls
                    ].join(' ').toLowerCase();

                    if (!searchableText.includes(searchText)) {
                        return false;
                    }
                }

                return true;
            });
        }

        // Render techniques
        function renderTechniques() {
            const filtered = filterTechniques();
            const container = document.getElementById('techniquesContainer');
            const noResults = document.getElementById('noResults');

            if (filtered.length === 0) {
                container.innerHTML = '';
                noResults.classList.remove('hidden');
                updateStats(filtered);
                return;
            }

            noResults.classList.add('hidden');

            // Group by component and stage
            const grouped = {};
            techniquesData.components.forEach(comp => {
                grouped[comp.id] = {
                    component: comp,
                    stages: {}
                };
            });

            filtered.forEach(tech => {
                if (!grouped[tech.component].stages[tech.stage]) {
                    grouped[tech.component].stages[tech.stage] = [];
                }
                grouped[tech.component].stages[tech.stage].push(tech);
            });

            // Render
            let html = '';
            techniquesData.components.forEach(comp => {
                const compData = grouped[comp.id];
                const stages = Object.keys(compData.stages);

                if (stages.length === 0) return;

                const color = componentColors[comp.id];
                const icon = componentIcons[comp.id];

                html += `
                    <div class="component-section">
                        <div class="component-header" style="border-color: ${color}">
                            <div class="component-icon" style="background-color: ${color}">
                                ${icon}
                            </div>
                            <div class="component-info">
                                <h2 style="color: ${color}">${comp.name}</h2>
                                <p>${comp.description}</p>
                            </div>
                        </div>
                `;

                // Sort stages
                const stageOrder = ['Initial Access', 'Discovery and Lateral Movement', 'Post-Compromise'];
                const sortedStages = stages.sort((a, b) => {
                    return stageOrder.indexOf(a) - stageOrder.indexOf(b);
                });

                sortedStages.forEach(stage => {
                    const techniques = compData.stages[stage];
                    html += `
                        <div class="stage-group">
                            <div class="stage-header">
                                <div class="stage-title">${stage}</div>
                                <div class="stage-count">${techniques.length}</div>
                            </div>
                            <div class="techniques-grid">
                    `;

                    techniques.forEach(tech => {
                        html += `
                            <div class="technique-card" id="${tech.id}">
                                <div class="technique-header">
                                    <div class="technique-id">${tech.id}</div>
                                    <button class="copy-link-btn" onclick="copyTechniqueLink('${tech.id}')" title="Copy link">🔗</button>
                                </div>
                                <div class="technique-name">${tech.name}</div>
                                <div class="technique-description">${tech.description}</div>
                                <div class="technique-details">
                                    <div class="detail-section">
                                        <div class="detail-title">⚠️ Risks</div>
                                        <ul class="detail-list risks-list">
                                            ${tech.risks.map(risk => `<li>${risk}</li>`).join('')}
                                        </ul>
                                    </div>
                                    ${(tech.controls?.protective || []).length > 0 ? `
                                    <div class="detail-section">
                                        <div class="detail-title">🛡️ Protective Controls</div>
                                        <ul class="detail-list controls-list" style="border-left: 3px solid #10B981;">
                                            ${(tech.controls?.protective || []).map(c => {
                                                const frameworkTags = formatFrameworkTags(c);
                                                return `<li>${c.name || c}${frameworkTags}</li>`;
                                            }).join('')}
                                        </ul>
                                    </div>
                                    ` : ''}
                                    ${(tech.controls?.detective || []).length > 0 ? `
                                    <div class="detail-section">
                                        <div class="detail-title">🔍 Detective Controls</div>
                                        <ul class="detail-list controls-list" style="border-left: 3px solid #F59E0B;">
                                            ${(tech.controls?.detective || []).map(c => {
                                                const rules = c.detectionRules || [];
                                                const ruleCount = rules.length > 0 ? ` <span style="color: #9D4EDD; font-size: 0.8em;">(${rules.length} rule${rules.length > 1 ? 's' : ''})</span>` : '';
                                                const frameworkTags = formatFrameworkTags(c);
                                                return `<li>${c.name || c}${ruleCount}${frameworkTags}</li>`;
                                            }).join('')}
                                        </ul>
                                    </div>
                                    ` : ''}
                                </div>
                            </div>
                        `;
                    });

                    html += `
                            </div>
                        </div>
                    `;
                });

                html += `</div>`;
            });

            container.innerHTML = html;
            updateStats(filtered);
        }

        // Update stats
        function updateStats(filtered) {
            const stats = document.getElementById('stats');
            
            const componentCount = new Set(filtered.map(t => t.component)).size;
            const stageCount = new Set(filtered.map(t => t.stage)).size;
            const totalRisks = filtered.reduce((sum, t) => sum + t.risks.length, 0);
            const totalProtective = filtered.reduce((sum, t) => sum + (t.controls?.protective?.length || 0), 0);
            const totalDetective = filtered.reduce((sum, t) => sum + (t.controls?.detective?.length || 0), 0);
            const totalControls = totalProtective + totalDetective;

            stats.innerHTML = `
                <div class="stat-item">
                    <div class="stat-number">${filtered.length}</div>
                    <div class="stat-label">Techniques</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">${componentCount}</div>
                    <div class="stat-label">Components</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">${stageCount}</div>
                    <div class="stat-label">Attack Stages</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">${totalRisks}</div>
                    <div class="stat-label">Risks</div>
                </div>
                <div class="stat-item">
                    <div class="stat-number">${totalControls}</div>
                    <div class="stat-label">Controls</div>
                </div>
            `;
        }

        // Copy technique link to clipboard
        function copyTechniqueLink(techId) {
            const url = `${window.location.origin}${window.location.pathname}#${techId}`;
            navigator.clipboard.writeText(url).then(() => {
                const btn = document.querySelector(`#${techId} .copy-link-btn`);
                btn.textContent = '✓';
                btn.classList.add('copied');
                setTimeout(() => {
                    btn.textContent = '🔗';
                    btn.classList.remove('copied');
                }, 1500);
            });
        }

        // Handle URL hash - scroll to and highlight technique
        function handleHashNavigation() {
            const hash = window.location.hash.slice(1);
            if (hash && hash.match(/^T-[A-Z]\d{3}$/)) {
                // Clear filters to ensure the technique is visible
                filters.component = 'all';
                filters.stage = 'all';
                filters.search = '';

                // Update filter button states
                document.querySelectorAll('#componentFilters .filter-btn').forEach(btn => {
                    btn.classList.toggle('active', btn.dataset.filter === 'all');
                });
                document.querySelectorAll('#stageFilters .filter-btn').forEach(btn => {
                    btn.classList.toggle('active', btn.dataset.filter === 'all');
                });
                document.getElementById('searchBox').value = '';

                // Re-render to show all techniques
                renderTechniques();

                // Scroll to technique after render
                setTimeout(() => {
                    const element = document.getElementById(hash);
                    if (element) {
                        element.scrollIntoView({ behavior: 'smooth', block: 'center' });
                        element.classList.add('highlighted');
                    }
                }, 100);
            }
        }

        // Listen for hash changes
        window.addEventListener('hashchange', handleHashNavigation);

        // Start
        init();

        // Handle initial hash if present
        if (window.location.hash) {
            handleHashNavigation();
        }
    </script>
</body>
</html>
