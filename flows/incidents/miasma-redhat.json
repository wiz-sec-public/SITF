              "frameworks": {
                "spvs": [
                  "V2.6",
                  "V3.4"
                ]
              }
            },
            {
              "name": "Package version pinning with hash verification",
              "description": "Pin exact versions with integrity hashes to prevent substitution",
              "frameworks": {
                "spvs": [
                  "V2.6",
                  "V3.4"
                ]
              }
            },
            {
              "name": "Python .pth file restrictions",
              "description": "Audit and restrict .pth file creation in site-packages directories",
              "frameworks": {
                "spvs": [
                  "V2.6",
                  "V3.1"
                ]
              }
            }
          ],
          "detective": [
            {
              "name": "Lifecycle script content analysis",
